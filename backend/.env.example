# MongoDB Configuration
MONGO_URI=mongodb://localhost:27017/diabetes_system

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_here_minimum_32_characters_required
REFRESH_TOKEN_SECRET=your_refresh_token_secret_here_minimum_32_characters

GOOGLE_CLIENT_ID=your_google_client_id_here.apps.googleusercontent.com
AUTH_COOKIE_CROSS_SITE=true

# Encryption Configuration (Generate using: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
ENCRYPTION_KEY=your_32_character_hex_encryption_key_here

# Server Configuration
PORT=5000

# Diabetica 7B LLM endpoint
# Set to your model endpoint base URL.
LLM_API_URL=https://YOUR-LLM-ENDPOINT

# Backward compatible variable used by hybrid risk service
DIABETICA_HF_URL=https://YOUR-USERNAME-diabetica-api.hf.space/api/predict

# Jina AI Embeddings (replaces local @xenova/transformers, free 1M tokens/month)
# Get free key at https://jina.ai
JINA_API_KEY=your_jina_api_key_here

# Qdrant Cloud Vector DB (replaces local ChromaDB, 1GB free forever)
# Get free cluster at https://cloud.qdrant.io
QDRANT_URL=https://YOUR-CLUSTER.cloud.qdrant.io
QDRANT_API_KEY=your_qdrant_api_key_here

# RAG enablement (set to true once Qdrant + Jina are configured)
RAG_ENABLED=false

# Legacy ChromaDB (no longer needed when RAG_ENABLED=false)
# CHROMA_DB_HOST=http://127.0.0.1:8000

# Email Configuration (Gmail SMTP - requires app-specific password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_gmail_app_specific_password

# Optional: Node Environment
NODE_ENV=development
