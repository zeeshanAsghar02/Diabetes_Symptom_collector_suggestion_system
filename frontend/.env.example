# Backend API Configuration (base URL only, without /api/v1)
# In Azure, set this to the deployed backend URL, for example https://your-api.azurecontainerapps.io
VITE_API_URL=http://localhost:5000
VITE_GOOGLE_CLIENT_ID=your_google_client_id_here.apps.googleusercontent.com

# Optional: Development Mode
VITE_DEV_MODE=true
